<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>新しいTodo作成 - Todo App</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-container">
                <h1><a href="/">Todo App</a></h1>
                <ul class="nav-menu">
                    <li><a href="/">すべてのTodo</a></li>
                    <li><a href="/create" class="btn btn-primary">新しいTodo</a></li>
                </ul>
            </div>
        </nav>
    </header>

    <main class="container">
        <div class="page-header">
            <h2>新しいTodoを作成</h2>
            <a href="/" class="btn btn-secondary">戻る</a>
        </div>

        <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-error">
                <%= error %>
            </div>
        <% } %>

        <form method="POST" action="/create" class="todo-form">
            <div class="form-group">
                <label for="title">タイトル <span class="required">*</span></label>
                <input type="text" id="title" name="title" required 
                       value="<%= typeof formData !== 'undefined' ? formData.title || '' : '' %>">
            </div>

            <div class="form-group">
                <label for="content">内容</label>
                <textarea id="content" name="content" rows="4"><%= typeof formData !== 'undefined' ? formData.content || '' : '' %></textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="deadline">期限</label>
                    <input type="date" id="deadline" name="deadline"
                           value="<%= typeof formData !== 'undefined' ? formData.deadline || '' : '' %>">
                </div>

                <div class="form-group">
                    <label for="priority">優先度</label>
                    <select id="priority" name="priority">
                        <option value="1" <%= typeof formData !== 'undefined' && formData.priority == '1' ? 'selected' : '' %>>低</option>
                        <option value="2" <%= typeof formData !== 'undefined' && formData.priority == '2' ? 'selected' : '' %>>中</option>
                        <option value="3" <%= typeof formData !== 'undefined' && formData.priority == '3' ? 'selected' : '' %>>高</option>
                    </select>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">作成</button>
                <a href="/" class="btn btn-secondary">キャンセル</a>
            </div>
        </form>
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2024 Todo App</p>
        </div>
    </footer>
</body>
</html>